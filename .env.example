# ads-mcp-servers — environment variable template
# Copy to .env and fill in real values. NEVER commit .env.
#
# Each service reads these at container start.
# In Railway production, set these under Service → Variables (not via this file).

# ============================================================
# amazon-ads (EPIC-001) — openbridge/amazon-ads-mcp
# ============================================================

# Server / runtime
TRANSPORT=http
HOST=0.0.0.0
PORT=9080
LOG_LEVEL=INFO

# Authentication (use AUTH_METHOD=direct for BYOA OAuth credentials)
AUTH_METHOD=direct
AMAZON_AD_API_CLIENT_ID=
AMAZON_AD_API_CLIENT_SECRET=
AMAZON_AD_API_REFRESH_TOKEN=

# Default profile scope (also accepted as AMAZON_AD_API_PROFILE_ID)
AMAZON_ADS_PROFILE_ID=

# Region: na (North America) | eu (Europe) | fe (Far East)
AMAZON_ADS_REGION=na

# Comma-separated tool packages to enable
# Phase 1: profiles,sponsored-products,reporting-version-3
AMAZON_AD_API_PACKAGES=

# Token persistence (recommended — set cache dir for Docker)
AMAZON_ADS_TOKEN_PERSIST=true
AMAZON_ADS_CACHE_DIR=/app/.cache/amazon-ads-mcp

